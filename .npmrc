shamefully-hoist=false
strict-peer-dependencies=false

# mermaid -> langium has undeclared transitive deps (chevrotain sub-packages,
# vscode-languageserver-types). Hoist them so Vite/Rollup can resolve.
public-hoist-pattern[]=*langium*
public-hoist-pattern[]=*chevrotain*
public-hoist-pattern[]=vscode-languageserver*
public-hoist-pattern[]=vscode-uri
