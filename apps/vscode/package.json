{
  "name": "md-feedback-vscode",
  "displayName": "MD Feedback",
  "description": "Annotate markdown plans with Fix/Question/Highlight in VS Code, then let AI agents read and execute your feedback via MCP. Free for personal and non-commercial use (SUL-1.0).",
  "version": "1.5.4",
  "publisher": "yeominux",
  "license": "SUL-1.0",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e293b",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yeominux/md-feedback"
  },
  "homepage": "https://github.com/yeominux/md-feedback#readme",
  "bugs": {
    "url": "https://github.com/yeominux/md-feedback/issues"
  },
  "qna": "marketplace",
  "markdown": "github",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Linters"
  ],
  "keywords": [
    "markdown",
    "feedback",
    "annotation",
    "review",
    "plan-review",
    "ai",
    "ai-agent",
    "ai-coding",
    "mcp-server",
    "vibe-coding",
    "developer-tools",
    "quality-gate",
    "handoff",
    "approve-reject",
    "visual-review"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "md-feedback",
          "title": "MD Feedback",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "md-feedback": [
        {
          "type": "webview",
          "id": "md-feedback.panel",
          "name": "Review"
        }
      ]
    },
    "commands": [
      {
        "command": "md-feedback.exportClaude",
        "title": "Export: Claude Code (CLAUDE.md)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportCursor",
        "title": "Export: Cursor (.cursor/rules/)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportCodex",
        "title": "Export: Codex (AGENTS.md)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportCopilot",
        "title": "Export: GitHub Copilot (.github/copilot-instructions.md)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportCline",
        "title": "Export: Cline (.clinerules)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportWindsurf",
        "title": "Export: Windsurf (.windsurfrules)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportRooCode",
        "title": "Export: Roo Code (.roo/rules/)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportGemini",
        "title": "Export: Gemini (.gemini/styleguide.md)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportAntigravity",
        "title": "Export: Antigravity (.agent/rules/)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportGeneric",
        "title": "Export: Generic Markdown",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportPicker",
        "title": "Export: Pick Target",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportAll",
        "title": "Export: All Tools (write all context files)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.checkpoint",
        "title": "Save Review Snapshot",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportHandoff",
        "title": "Export: Handoff Document",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.showOnboarding",
        "title": "Show Onboarding",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.approveMemo",
        "title": "Approve Annotation",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.requestChangesMemo",
        "title": "Request Changes on Annotation",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.rejectMemo",
        "title": "Reject Annotation",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.approveNearest",
        "title": "Approve Nearest Annotation",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.rejectNearest",
        "title": "Reject Nearest Annotation",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.annotateHighlight",
        "title": "Add Highlight Annotation from Selection",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.annotateFix",
        "title": "Add Fix Annotation from Selection",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.annotateQuestion",
        "title": "Add Question Annotation from Selection",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.openDetails",
        "title": "Open Review Details",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.reopenTips",
        "title": "Show Quick Tips Again",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.panel.focus",
        "title": "Open MD Feedback Sidebar",
        "category": "MD Feedback"
      }
    ],
    "keybindings": [
      {
        "command": "md-feedback.annotateHighlight",
        "key": "1",
        "when": "editorTextFocus && editorLangId == markdown && editorHasSelection"
      },
      {
        "command": "md-feedback.annotateFix",
        "key": "2",
        "when": "editorTextFocus && editorLangId == markdown && editorHasSelection"
      },
      {
        "command": "md-feedback.annotateQuestion",
        "key": "3",
        "when": "editorTextFocus && editorLangId == markdown && editorHasSelection"
      },
      {
        "command": "md-feedback.approveNearest",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorLangId == markdown"
      },
      {
        "command": "md-feedback.rejectNearest",
        "key": "ctrl+shift+x",
        "mac": "cmd+shift+x",
        "when": "editorLangId == markdown"
      },
      {
        "command": "md-feedback.exportPicker",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorLangId == markdown"
      },
      {
        "command": "md-feedback.openDetails",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorLangId == markdown"
      },
      {
        "command": "md-feedback.reopenTips",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h",
        "when": "editorLangId == markdown"
      }
    ],
    "walkthroughs": [
      {
        "id": "md-feedback.getting-started",
        "title": "Get Started with MD Feedback",
        "description": "Start annotating in under 2 minutes.",
        "steps": [
          {
            "id": "open-sidebar",
            "title": "1) Open MD Feedback sidebar",
            "description": "Run `MD Feedback: Open MD Feedback Sidebar`.",
            "completionEvents": [
              "onCommand:md-feedback.panel.focus"
            ]
          },
          {
            "id": "create-annotation",
            "title": "2) Create your first annotation",
            "description": "Select text in a markdown file, then press `2` for a Fix annotation.",
            "completionEvents": [
              "onCommand:md-feedback.annotateFix"
            ]
          },
          {
            "id": "optional-mcp",
            "title": "3) (Optional) Connect MCP",
            "description": "In the sidebar, click `Connect AI` after your first annotation to see MCP setup."
          }
        ]
      }
    ],
    "configuration": {
      "title": "MD Feedback",
      "properties": {
        "md-feedback.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "enumDescriptions": [
            "Match VS Code color theme",
            "Always use light theme",
            "Always use dark theme"
          ],
          "description": "Controls the MD Feedback panel theme."
        },
        "md-feedback.autoCheckpointIntervalMs": {
          "type": "number",
          "default": 600000,
          "minimum": 1000,
          "description": "Auto-checkpoint interval in milliseconds."
        },
        "md-feedback.sectionTrackDebounceMs": {
          "type": "number",
          "default": 3000,
          "minimum": 50,
          "description": "Debounce delay for section tracking from cursor movement (milliseconds)."
        },
        "md-feedback.editorSwitchDebounceMs": {
          "type": "number",
          "default": 150,
          "minimum": 10,
          "description": "Debounce delay for active editor changes (milliseconds)."
        },
        "md-feedback.fileWatchDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 10,
          "description": "Debounce delay for external file watcher updates (milliseconds)."
        }
      }
    }
  },
  "sponsor": {
    "url": "https://buymeacoffee.com/ymnseon8"
  },
  "scripts": {
    "test": "vitest run",
    "build": "node esbuild.mjs && vite build",
    "build:ext": "node esbuild.mjs",
    "build:webview": "vite build",
    "watch:ext": "node esbuild.mjs --watch",
    "dev": "concurrently \"npm run watch:ext\" \"vite build --watch\"",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@md-feedback/shared": "workspace:*",
    "@tiptap/extension-code-block-lowlight": "^2.27.2",
    "lowlight": "^3.1.0",
    "mermaid": "^11.5.1"
  },
  "devDependencies": {
    "@chevrotain/cst-dts-gen": "^11.1.1",
    "@chevrotain/gast": "^11.1.1",
    "@chevrotain/regexp-to-ast": "^11.1.1",
    "@chevrotain/types": "^11.1.1",
    "@chevrotain/utils": "^11.1.1",
    "@popperjs/core": "^2.11.8",
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-bubble-menu": "^2.11.5",
    "@tiptap/extension-highlight": "^2.11.5",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/vsce": "^3.7.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "lodash-es": "^4.17.23",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.1.2",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.8.10",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5"
  }
}
