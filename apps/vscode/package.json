{
  "name": "md-feedback-vscode",
  "displayName": "MD Feedback",
  "description": "Annotate markdown plans with Fix/Question/Highlight in VS Code, then let AI agents read and execute your feedback via MCP.",
  "version": "1.3.1",
  "publisher": "yeominux",
  "license": "SUL-1.0",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e293b",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yeominux/md-feedback"
  },
  "homepage": "https://github.com/yeominux/md-feedback#readme",
  "bugs": {
    "url": "https://github.com/yeominux/md-feedback/issues"
  },
  "qna": "marketplace",
  "markdown": "github",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "plan-review",
    "markdown-annotation",
    "ai-coding",
    "mcp-server",
    "vibe-coding",
    "markdown",
    "review",
    "feedback",
    "annotation",
    "ai",
    "claude",
    "cursor",
    "copilot",
    "handoff",
    "ai-agent",
    "export",
    "context",
    "code-review",
    "structured-feedback",
    "markdown-review",
    "ai-context",
    "coding-workflow",
    "developer-tools",
    "visual-review",
    "productivity",
    "approve-reject",
    "gate-control",
    "inline-diff"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "md-feedback",
          "title": "MD Feedback",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "md-feedback": [
        {
          "type": "webview",
          "id": "md-feedback.panel",
          "name": "Review"
        }
      ]
    },
    "commands": [
      {
        "command": "md-feedback.exportClaude",
        "title": "Export: Claude Code (CLAUDE.md)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportCursor",
        "title": "Export: Cursor (.cursor/rules/)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportCodex",
        "title": "Export: Codex (AGENTS.md)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportCopilot",
        "title": "Export: GitHub Copilot (.github/copilot-instructions.md)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportCline",
        "title": "Export: Cline (.clinerules)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportWindsurf",
        "title": "Export: Windsurf (.windsurfrules)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportRooCode",
        "title": "Export: Roo Code (.roo/rules/)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportGemini",
        "title": "Export: Gemini (.gemini/styleguide.md)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportAntigravity",
        "title": "Export: Antigravity (.agent/rules/)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportGeneric",
        "title": "Export: Generic Markdown",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportAll",
        "title": "Export: All Tools (write all context files)",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.checkpoint",
        "title": "Create Checkpoint",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.exportHandoff",
        "title": "Export: Handoff Document",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.showOnboarding",
        "title": "Show Onboarding",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.approveMemo",
        "title": "Approve Annotation",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.requestChangesMemo",
        "title": "Request Changes on Annotation",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.rejectMemo",
        "title": "Reject Annotation",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.approveNearest",
        "title": "Approve Nearest Annotation",
        "category": "MD Feedback"
      },
      {
        "command": "md-feedback.rejectNearest",
        "title": "Reject Nearest Annotation",
        "category": "MD Feedback"
      }
    ],
    "keybindings": [
      {
        "command": "md-feedback.approveNearest",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorLangId == markdown"
      },
      {
        "command": "md-feedback.rejectNearest",
        "key": "ctrl+shift+x",
        "mac": "cmd+shift+x",
        "when": "editorLangId == markdown"
      }
    ],
    "configuration": {
      "title": "MD Feedback",
      "properties": {
        "md-feedback.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "enumDescriptions": [
            "Match VS Code color theme",
            "Always use light theme",
            "Always use dark theme"
          ],
          "description": "Controls the MD Feedback panel theme."
        }
      }
    }
  },
  "sponsor": {
    "url": "https://buymeacoffee.com/ymnseon8"
  },
  "scripts": {
    "build": "node esbuild.mjs && vite build",
    "build:ext": "node esbuild.mjs",
    "build:webview": "vite build",
    "watch:ext": "node esbuild.mjs --watch",
    "dev": "concurrently \"npm run watch:ext\" \"vite build --watch\"",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@md-feedback/shared": "workspace:*",
    "@tiptap/extension-code-block-lowlight": "^2.27.2",
    "lowlight": "^3.1.0",
    "mermaid": "^11.5.1"
  },
  "devDependencies": {
    "@chevrotain/cst-dts-gen": "^11.1.1",
    "@chevrotain/gast": "^11.1.1",
    "@chevrotain/regexp-to-ast": "^11.1.1",
    "@chevrotain/types": "^11.1.1",
    "@chevrotain/utils": "^11.1.1",
    "@popperjs/core": "^2.11.8",
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-bubble-menu": "^2.11.5",
    "@tiptap/extension-highlight": "^2.11.5",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/vsce": "^3.7.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "lodash-es": "^4.17.23",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.1.2",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.8.10",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5"
  }
}
